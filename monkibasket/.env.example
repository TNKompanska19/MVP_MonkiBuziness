# MonkiBasket — local environment template
#
# Copy this file to `.env` (same folder) and fill in your keys.
# `.env` is gitignored — never commit real tokens.
#
# Get your keys here (both free):
#   - GitHub Models PAT:   https://github.com/settings/tokens  (any scopes; used as Bearer for the gpt-4o-mini endpoint)
#   - SerpAPI Google Shop: https://serpapi.com/  (1,000 free searches/month)

GITHUB_TOKEN=your_github_pat_here
SERPAPI_KEY=your_serpapi_key_here
